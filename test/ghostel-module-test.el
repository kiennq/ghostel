(ert-deftest ghostel-test-download-module-closes-live-buffers-before-reload ()
  "Downloading over a loader runtime closes live terminals before reload."
  (let ((system-type 'windows-nt)
        (module-file-suffix ".dll")
        (ghostel-module-dir "C:/ghostel/")
        (downloaded nil)
        (checked nil)
        (closed nil)
        (reloaded nil)
        (original-featurep (symbol-function 'featurep)))
    (ghostel-test--without-subr-trampolines
      (cl-letf (((symbol-function 'file-exists-p)
                 (lambda (_) nil))
                ((symbol-function 'ghostel--download-module)
                 (lambda (_dir &optional _version _latest-release)
                   (setq downloaded t)
                   t))
                ((symbol-function 'ghostel--native-runtime-ready-p)
                 (lambda () t))
                ((symbol-function 'featurep)
                 (lambda (feature)
                   (or (eq feature 'dyn-loader-module)
                       (funcall original-featurep feature))))
                ((symbol-function 'ghostel--loader-loaded-modules)
                 (lambda () '("ghostel" "conpty-module")))
                ((symbol-function 'ghostel--live-buffers)
                 (lambda () (list (current-buffer))))
                ((symbol-function 'ghostel--close-live-buffers)
                 (lambda (buffers)
                   (setq closed buffers)))
                ((symbol-function 'dyn-loader-reload)
                 (lambda (&rest _)
                   (setq reloaded t)))
                ((symbol-function 'ghostel--check-module-version)
                 (lambda (&rest _)
                   (setq checked t)))
                ((symbol-function 'message)
                 (lambda (&rest _) nil)))
        (ghostel-download-module)
        (should downloaded)
        (should (equal (list (current-buffer)) closed))
        (should reloaded)
        (should checked)))))

