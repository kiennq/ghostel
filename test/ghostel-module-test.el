                   (setq published (list source-dir dest-dir)))))
        (should (ghostel--compile-module "/custom/dir/"))
        (should-not warnings)
        (should (equal (list (downcase (expand-file-name "zig-out/bin" "/src/ghostel/"))
                             (downcase "/custom/dir/"))
                       (mapcar #'downcase published)))))))

