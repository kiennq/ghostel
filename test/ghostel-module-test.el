                   (lambda (&rest _) nil))
                  ((symbol-function 'conpty--init)
                   (lambda (&rest _) nil))
                  ((symbol-function 'featurep)
                   (lambda (feature)
                     (or (memq feature '(ghostel-module conpty-module))
                         (and (not (eq feature 'dyn-loader-module))
